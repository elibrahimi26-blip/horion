# ──────────────────────────────────────────────────────────────────
# Configuration de production Horion
# ──────────────────────────────────────────────────────────────────
# À copier en .env.production sur le VPS et remplir les valeurs.
# NE JAMAIS commit ce fichier rempli (déjà dans .gitignore).
# ──────────────────────────────────────────────────────────────────

# ─── Domaine d'accès ───
# Format sslip.io : remplace les "." de l'IP par des "-"
# Exemple si VPS = 91.234.5.6 :  DOMAIN=horion.91-234-5-6.sslip.io
# Plus tard avec un vrai domaine :  DOMAIN=horion.fr
DOMAIN=horion.IP-AVEC-DES-TIRETS.sslip.io

# ─── Base de données ───
# Le mot de passe est utilisé par Postgres ET par l'app (via DATABASE_URL)
DB_PASSWORD=CHANGE_ME_GENERATE_RANDOM_32_CHARS
DATABASE_URL=postgresql://horion:CHANGE_ME_GENERATE_RANDOM_32_CHARS@db:5432/horion?schema=public

# ─── Auth.js v5 ───
# Générer avec : openssl rand -base64 32
NEXTAUTH_URL=https://horion.IP-AVEC-DES-TIRETS.sslip.io
NEXTAUTH_SECRET=CHANGE_ME_openssl_rand_base64_32

NODE_ENV=production

# ─── Email admin ───
# Ton email pour recevoir les notifs admin (nouvelles inscriptions, etc.)
# ET pour Let's Encrypt (Caddy l'utilise comme contact)
ADMIN_EMAIL=ton.email@gmail.com

# ─── Email transactionnel (Resend) ───
# Optionnel pour le premier déploiement — les emails iront dans les logs
# Plus tard : créer un compte sur https://resend.com (3000 emails/mois gratuits)
RESEND_API_KEY=
EMAIL_FROM=Horion <noreply@horion.local>

# ─── Cloudflare R2 (stockage avatars + GIF) ───
# Optionnel pour le premier déploiement — l'upload d'avatar sera désactivé
# Plus tard : créer un compte sur https://www.cloudflare.com/products/r2/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_AVATARS=
R2_BUCKET_EXERCISES=
R2_BUCKET_BACKUPS=
R2_PUBLIC_URL=

# ─── Rate limiting (Upstash Redis) ───
# Optionnel — protège contre le brute-force sur /login
# Plus tard : créer un compte sur https://upstash.com (10k req/jour gratuits)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
