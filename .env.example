R2_BUCKET_AVATARS="horion-avatars"
R2_BUCKET_EXERCISES="horion-exercises"
R2_BUCKET_BACKUPS="horion-backups"
R2_PUBLIC_URL=""

# ────── Email (Resend) ──────
RESEND_API_KEY=""
